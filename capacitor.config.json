{
  "appId": "com.spotifyguess.app",
  "appName": "EchoGuess",
  "webDir": "dist",
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#121212",
    "allowsLinkPreview": false,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "allowNavigation": [
      "*.spotify.com",
      "*.scdn.co",
      "*.apple.com",
      "*.mzstatic.com",
      "itunes.apple.com",
      "*.deezer.com",
      "*.dzcdn.net"
    ]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    }
  }
}
