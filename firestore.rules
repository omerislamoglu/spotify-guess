rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rooms ──────────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      // Any signed-in user (including anonymous) can read a room.
      allow read: if request.auth != null;

      // Any signed-in user can create a room.
      allow create: if request.auth != null;

      // Any authenticated user can update a room that is still in lobby or playing phase.
      // Fine-grained ownership checks happen in client code (useGameStore).
      allow update: if request.auth != null
                    && resource.data.phase in ['lobby', 'playing', 'finished'];
    }

    // ── User profiles ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
