rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rooms ──────────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      // Any signed-in user (including anonymous) can read a room.
      allow read: if request.auth != null;

      // Any signed-in user can create a room.
      allow create: if request.auth != null;

      // Only the host, a current player, or a user joining the lobby can update.
      // This prevents outsiders from manipulating scores, rounds, or phase.
      allow update: if request.auth != null
                    && resource.data.phase in ['lobby', 'playing', 'finished']
                    && (
                      // Host can always update
                      request.auth.uid == resource.data.hostId
                      // Players already in the room can update (guesses, playlists, leave)
                      || request.auth.uid in resource.data.players.map(p, p.uid)
                      // New player joining the lobby — they're being added to players array
                      || (resource.data.phase == 'lobby'
                          && request.auth.uid in request.resource.data.players.map(p, p.uid))
                    );

      // Allow a player in the room to delete it (used when last player leaves).
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.players.map(p, p.uid);
    }

    // ── User profiles ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasAny(['isPremium', 'premiumProductId', 'premiumUpdatedAt', 'diamonds']);
    }

    // ── Webhook idempotency (server-only) ────────────────────────────────────
    match /processed_events/{eventId} {
      allow read, write: if false;
    }
  }
}
