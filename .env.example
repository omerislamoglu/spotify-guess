# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Firebase — get these from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Spotify — get from Spotify Developer Dashboard > Your App
VITE_SPOTIFY_CLIENT_ID=
# Must exactly match a URI added in your Spotify App's Redirect URIs list.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
