# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Firebase — https://console.firebase.google.com → Project Settings → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Spotify — https://developer.spotify.com/dashboard → App → Settings
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# AdMob — https://admob.google.com → Apps → Ad units
VITE_ADMOB_INTERSTITIAL_IOS=
VITE_ADMOB_REWARDED_IOS=
VITE_ADMOB_INTERSTITIAL_ANDROID=
VITE_ADMOB_REWARDED_ANDROID=

# RevenueCat — https://app.revenuecat.com → Project → API Keys
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=

# App URL — used for share links (Firebase Hosting domain)
VITE_APP_URL=https://spotify-guess-30d26.web.app
